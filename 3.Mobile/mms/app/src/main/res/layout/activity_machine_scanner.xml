<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll_scanner_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/rl_scanner_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:contentDescription="@null"
            android:padding="4dp"
            android:src="@drawable/back_24" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Nhập mã thiết bị"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/iv_scan_illustration"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#B8C7DE"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tv_scan_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quét mã bằng tia laser của PDA hoặc nhập tay vào ô dưới"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_input_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#B8C7DE"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/et_machine_code_input"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:hint="Nhập hoặc quét mã máy..."
                android:inputType="textCapCharacters"
                android:paddingHorizontal="16dp"
                android:textColor="#111827"
                android:textSize="15sp"
                android:singleLine="true"
                android:imeOptions="actionDone"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_btn_submit"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_btn_add"
            android:gravity="center"
            android:text="Xác nhận"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>