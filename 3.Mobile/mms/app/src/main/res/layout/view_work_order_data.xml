<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#D4D9E2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"> <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_card_no"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_filter_segment_selected"
            android:gravity="center"
            android:text="1"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_card_wo_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WO-20260420"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_card_machine_inline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="#EFF6FF"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="HAAS CNC"
                    android:textColor="#2563EB"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_card_request_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày quét: 2026/05/22"
                    android:textColor="#6B7280"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_card_wo_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_filter_segment_unselected"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Pending"
                android:textColor="#1F2937"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_card_edit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_action_icon_edit"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_pencil"
                app:tint="#2563EB" />
        </LinearLayout>
    </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#E5E7EB" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CHI TIẾT CÔNG VIỆC"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_card_hang_muc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Hạng mục: Bảo dưỡng định kỳ cấp độ 2"
                    android:textColor="#111827"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_card_work_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Loại hình: BM (Breakdown Maintenance)"
                    android:textColor="#111827"
                    android:textSize="13sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginVertical="10dp"
                android:background="#E5E7EB" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NHÂN SỰ PHÂN CÔNG"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_card_nguoi_phu_trach"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Người phụ trách: Nguyễn Văn A (Manager)"
                    android:textColor="#111827"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_card_nguoi_thuc_hien"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Người thực hiện: Trần Văn B (Technician)"
                    android:textColor="#111827"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_card_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#F9FAFB"
            android:padding="8dp"
            android:text="Ghi chú hệ thống: Kiểm tra kỹ các trục khớp và thay dầu nhớt thủy lực."
            android:textColor="#374151"
            android:textSize="11sp"
            android:textStyle="italic" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>