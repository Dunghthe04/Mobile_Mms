<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="16dp"
    tools:context=".ui.taskdetail.TaskDetailActivity">


    <androidx.cardview.widget.CardView
        android:id="@+id/card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/white"
        android:layout_alignParentTop="true"

        >

        <com.google.android.flexbox.FlexboxLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@color/white"
            android:orientation="horizontal">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_flexBasisPercent="15%"
                android:background="@color/white"
                >
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="10dp"
                    android:layout_centerHorizontal="true"
                    android:src="@drawable/back_24">

                </ImageView>

            </RelativeLayout>

            <TextView
                android:id="@+id/lable_screen_header"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:textAlignment="center"
                android:layout_marginVertical="4dp"
                android:text="HỆ THỐNG QUẢN LÝ BẢO TRÌ"
                app:layout_flexBasisPercent="70%"
                android:textColor="@color/black"
                android:textSize="27sp"
                />


            <ImageView
                android:id="@+id/language_menu_inventory_scan"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:visibility="gone"
                android:layout_centerVertical="true"
                android:layout_alignParentRight="true"
                android:padding="10dp"
                android:src="@drawable/translation_2"/>


            <RelativeLayout
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                app:layout_alignSelf="center"
                app:layout_flexBasisPercent="15%"
                android:background="@color/white"
                >

                <ImageView
                    android:id="@+id/user_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/user_icon"
                    android:layout_centerHorizontal="true"
                    >

                </ImageView>


                <TextView
                    android:id="@+id/user_id_login"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/user_icon"
                    android:layout_centerHorizontal="true"
                    android:gravity="center"
                    android:text="028355"
                    android:textSize="13sp"
                    >

                </TextView>

            </RelativeLayout>


        </com.google.android.flexbox.FlexboxLayout>






    </androidx.cardview.widget.CardView>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="105dp"
        android:layout_below="@+id/card_view"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="15dp"
            >


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <LinearLayout
                    android:id="@+id/lable_pre_maintain_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_vertical"
                    >
                    <RelativeLayout
                        android:id="@+id/lay_out_pre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_vertical">

                        <TextView
                            android:id="@+id/txtpre_maintainlabel"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:textColor="@color/black"
                            android:text="Kiểm tra trước bảo trì"
                            android:textStyle="bold"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="10dp"
                            android:textSize="16sp"
                            android:layout_centerVertical="true"/>

                        <LinearLayout
                            android:id="@+id/btn_show_list_pre_maintain"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:gravity="center"
                            >
                            <TextView
                                android:id="@+id/txt_lable_show_list_pre_maintain"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thu gọn"
                                android:textSize="14sp"
                                android:textColor="#01A789"
                                >
                            </TextView>
                            <ImageView
                                android:id="@+id/img_show_list_pre_maintain"
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:padding="5dp"
                                android:src="@drawable/arrow_line"
                                >

                            </ImageView>
                        </LinearLayout>



                    </RelativeLayout>

                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rcv_list_pre_maintain"
                    android:layout_below="@+id/lable_pre_maintain_header"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:visibility="gone"
                    >

                </androidx.recyclerview.widget.RecyclerView>


                <LinearLayout
                    android:id="@+id/lable_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_vertical"
                    android:layout_below="@+id/lable_pre_maintain_header"
                    >
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_vertical">

                        <TextView
                            android:id="@+id/txtsteplabel"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:textColor="@color/black"
                            android:text="Các bước thực hiện bảo trì"
                            android:textStyle="bold"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="10dp"
                            android:textSize="16sp"
                            android:layout_centerVertical="true"/>

                        <LinearLayout
                            android:id="@+id/btn_show_list"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:gravity="center"
                            >
                            <TextView
                                android:id="@+id/txt_lable_show_list"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thu gọn"
                                android:textSize="14sp"
                                android:textColor="#01A789"
                                >
                            </TextView>
                            <ImageView
                                android:id="@+id/img_show_list"
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:padding="5dp"
                                android:src="@drawable/arrow_line"
                                >

                            </ImageView>
                        </LinearLayout>



                    </RelativeLayout>

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rcv_list_intruction"
                    android:layout_below="@+id/lable_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:visibility="gone"
                    >

                </androidx.recyclerview.widget.RecyclerView>



                <TextView
                    android:id="@+id/txt_lable_machine_infor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/rcv_list_intruction"
                    android:text="Mã máy - Tên máy"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginLeft="16dp"
                    >

                </TextView>

                <TextView
                    android:id="@+id/txt_machine_infor"
                    android:layout_width="match_parent"
                    android:background="@drawable/layout_bg_black"
                    android:layout_height="60dp"
                    android:layout_below="@+id/txt_lable_machine_infor"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:padding="10dp"
                    android:textSize="16sp"
                    >

                </TextView>


                <TextView
                    android:id="@+id/txt_requests_arise_lable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_below="@+id/txt_machine_infor"
                    android:text="Yêu cầu phát sinh"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginLeft="16dp"
                    >

                </TextView>

                <TextView
                    android:id="@+id/txt_requests_arise"
                    android:layout_width="match_parent"
                    android:background="@drawable/layout_bg_black"
                    android:layout_height="60dp"
                    android:layout_below="@+id/txt_requests_arise_lable"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:padding="10dp"
                    android:textSize="16sp"
                    >

                </TextView>


                <TextView
                    android:id="@+id/txtlabel_note"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/txt_requests_arise"
                    android:layout_marginRight="12dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginLeft="16dp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:text="Ghi chú" />

                <EditText
                    android:id="@+id/txt_note"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:padding="10dp"
                    android:hint="Điền thông tin ghi chú"
                    android:textStyle="italic"
                    android:layout_below="@+id/txtlabel_note"
                    android:background="@drawable/layout_bg_black"
                    >

                </EditText>

                <TextView
                    android:id="@+id/txtlabel_Current_Situation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/txt_note"
                    android:layout_marginRight="5dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginLeft="16dp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:text="Hiện trạng" />

                <TextView
                    android:id="@+id/red_start_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_toEndOf="@+id/txtlabel_Current_Situation"
                    android:layout_below="@+id/txt_note"
                    android:textColor="@color/red"
                    android:textSize="14sp"
                    android:text="*"
                    />

                <EditText
                    android:id="@+id/txt_Current_Situation"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:padding="10dp"
                    android:hint="Điền thông tin hiện trạng"
                    android:textStyle="italic"
                    android:layout_below="@+id/txtlabel_Current_Situation"
                    android:background="@drawable/layout_bg_black"
                    >
                </EditText>

                <TextView
                    android:id="@+id/txtlabel_Root_Cause"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/txt_Current_Situation"
                    android:layout_marginRight="5dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginLeft="16dp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:text="Nguyên nhân" />

                <TextView
                    android:id="@+id/red_start_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_toEndOf="@+id/txtlabel_Root_Cause"
                    android:layout_below="@+id/txt_Current_Situation"
                    android:textColor="@color/red"
                    android:textSize="14sp"
                    android:text="*"
                    />

                <EditText
                    android:id="@+id/txt_Root_Cause"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:padding="10dp"
                    android:hint="Điền thông tin nguyên nhân"
                    android:textStyle="italic"
                    android:layout_below="@+id/txtlabel_Root_Cause"
                    android:background="@drawable/layout_bg_black"
                    >
                </EditText>

                <TextView
                    android:id="@+id/txtlabel_Action_Taken"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/txt_Root_Cause"
                    android:layout_marginRight="5dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginLeft="16dp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:text="Xử lý" />

                <TextView
                    android:id="@+id/red_start_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_toEndOf="@+id/txtlabel_Action_Taken"
                    android:layout_below="@+id/txt_Root_Cause"
                    android:textColor="@color/red"
                    android:textSize="14sp"
                    android:text="*"
                    />

                <EditText
                    android:id="@+id/txt_Action_Taken"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:padding="10dp"
                    android:hint="Điền thông tin xử lý"
                    android:textStyle="italic"
                    android:layout_below="@+id/txtlabel_Action_Taken"
                    android:background="@drawable/layout_bg_black"
                    >
                </EditText>

                <TextView
                    android:id="@+id/txtlabel_Countermeasure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/txt_Action_Taken"
                    android:layout_marginRight="5dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginLeft="16dp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:text="Đối sách" />

                <TextView
                    android:id="@+id/red_start_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_toEndOf="@+id/txtlabel_Countermeasure"
                    android:layout_below="@+id/txt_Action_Taken"
                    android:textColor="@color/red"
                    android:textSize="14sp"
                    android:text="*"
                    />

                <EditText
                    android:id="@+id/txt_Countermeasure"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:padding="10dp"
                    android:hint="Điền thông tin đối sách"
                    android:textStyle="italic"
                    android:layout_below="@+id/txtlabel_Countermeasure"
                    android:background="@drawable/layout_bg_black"
                    >
                </EditText>


                <TextView
                    android:id="@+id/txtlabel_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/txt_Countermeasure"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:text="Ảnh bảo trì" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rcv_image"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:orientation="horizontal"
                    android:layout_below="@+id/txtlabel_image"
                    >


                </androidx.recyclerview.widget.RecyclerView>


                <TextView
                    android:id="@+id/txt_lable_upload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:layout_below="@+id/rcv_image"
                    android:text="Tải lên file"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    >
                </TextView>

                <com.mkac.meikomms.ui.custom.UploadButton
                    android:id="@+id/pickImageBtn"
                    android:layout_width="272dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_below="@+id/txt_lable_upload"
                    >

                </com.mkac.meikomms.ui.custom.UploadButton>


                <ImageView
                    android:id="@+id/cameraBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/camera_40"
                    android:layout_below="@+id/txt_lable_upload"
                    android:layout_marginTop="8dp"
                    android:layout_marginLeft="15dp"
                    android:layout_toEndOf="@+id/pickImageBtn"
                    >
                </ImageView>

                <TextView
                    android:id="@+id/txt_lable_table_material"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="16dp"
                    android:layout_below="@+id/cameraBtn"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:text="Danh sách vật tư"
                    >

                </TextView>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/rcv_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_below="@+id/txt_lable_table_material"
                    android:layout_marginTop="5dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:background="#D1CFCF">

                    <!-- Machine Code -->
                    <TextView
                        android:id="@+id/txt_no"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="Stt"
                        android:textStyle="bold"
                        android:layout_marginLeft="1dp"
                        android:layout_marginTop="1dp"
                        android:background="#EFEFEF"
                        app:layout_flexBasisPercent="10%"
                        android:textColor="@color/black" />

                    <!-- Machine Code -->
                    <TextView
                        android:id="@+id/materialCode"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="Mã vật tư"
                        android:textStyle="bold"
                        android:layout_marginLeft="1dp"
                        android:layout_marginTop="1dp"
                        android:background="#EFEFEF"
                        app:layout_flexBasisPercent="20%"
                        android:textColor="@color/black" />


                    <!-- Maintenance Name -->
                    <TextView
                        android:id="@+id/materialName"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center"
                        app:layout_flexBasisPercent="52.5%"
                        android:textStyle="bold"
                        android:layout_marginLeft="1dp"
                        android:layout_marginTop="1dp"
                        android:textColor="@color/black"
                        android:background="#EFEFEF"
                        android:text="Tên vật tư"/>

                    <TextView
                        android:id="@+id/material_qty"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="Số lượng"
                        android:textStyle="bold"
                        android:layout_marginLeft="1dp"
                        android:layout_marginTop="1dp"
                        android:textColor="@color/black"
                        android:background="#EFEFEF"
                        app:layout_flexBasisPercent="13.75%"
                        />


                    <TextView
                        android:id="@+id/materialUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="Đơn vị"
                        android:textStyle="bold"
                        android:layout_marginLeft="1dp"
                        android:layout_marginTop="1dp"
                        android:layout_marginRight="1dp"
                        android:textColor="@color/black"
                        android:background="#EFEFEF"
                        app:layout_flexBasisPercent="13.75%"/>

                </com.google.android.flexbox.FlexboxLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rcv_material"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_below="@+id/rcv_header"
                    android:orientation="vertical"
                    android:background="@drawable/table_border"
                    >
                </androidx.recyclerview.widget.RecyclerView>


            </RelativeLayout>


        </LinearLayout>



    </ScrollView>


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:layout_marginBottom="55dp"
        >



        <RelativeLayout
            android:id="@+id/btn_add_list_material"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_alignParentBottom="true"
            android:layout_marginLeft="16dp"
            android:layout_marginBottom="20dp"
            android:visibility="invisible"
            android:background="@drawable/lay_out_conner_4_yellow_white"
            >

            <ImageView
                android:id="@+id/materialicon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:layout_marginLeft="7dp"
                android:src="@drawable/material_icon"
                >
            </ImageView>

            <TextView
                android:id="@+id/btn_material_lable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/materialicon"
                android:layout_centerVertical="true"
                android:textAlignment="center"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:text="Thêm vật tư"
                android:textSize="14sp"
                android:textColor="@color/black"
                >

            </TextView>




        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/btn_pause_work"
            android:layout_width="205dp"
            android:layout_height="48dp"
            android:layout_alignParentBottom="true"
            android:layout_marginLeft="16dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:visibility="invisible"
            android:layout_toEndOf="@+id/btn_add_list_material"
            android:background="@drawable/lay_out_conner_4_green_white"
            >

            <ImageView
                android:id="@+id/doworkicon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:layout_marginLeft="7dp"
                android:src="@drawable/icon_custom_button"
                >
            </ImageView>


            <TextView
                android:id="@+id/btn_dowork_lable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/doworkicon"
                android:layout_centerVertical="true"
                android:textAlignment="center"
                android:layout_marginLeft="5dp"
                android:text="Tạm dừng công việc"
                android:textSize="14sp"
                android:textColor="#01A789"
                >

            </TextView>


        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/btn_end_work"
            android:layout_width="205dp"
            android:layout_height="48dp"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="16dp"
            android:layout_marginLeft="16dp"
            android:layout_marginBottom="21dp"
            android:gravity="center"
            android:visibility="invisible"
            android:layout_toEndOf="@+id/btn_pause_work"
            android:background="@drawable/lay_out_conner_4_green_fill">

            <ImageView
                android:id="@+id/endworkicon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:layout_marginLeft="7dp"
                android:src="@drawable/icon_select_button"></ImageView>


            <TextView
                android:id="@+id/btn_endwork_lable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="5dp"
                android:layout_toEndOf="@+id/endworkicon"
                android:text="Hoàn thành công việc"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp">

            </TextView>


        </RelativeLayout>


    </RelativeLayout>



    <RelativeLayout
        android:id="@+id/btn_start_work"
        android:layout_width="285dp"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="55dp"
        android:gravity="center_horizontal"
        android:layout_centerHorizontal="true"
        android:background="@drawable/lay_out_conner_4_green_fill"
        >

        <ImageView
            android:id="@+id/startworkicon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="7dp"
            android:src="@drawable/icon_select_button"
            >
        </ImageView>


        <TextView
            android:id="@+id/btn_startwork_lable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/startworkicon"
            android:layout_centerVertical="true"
            android:textAlignment="center"
            android:layout_marginLeft="5dp"
            android:text="Bắt đầu bảo trì"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            >

        </TextView>


    </RelativeLayout>



</RelativeLayout>