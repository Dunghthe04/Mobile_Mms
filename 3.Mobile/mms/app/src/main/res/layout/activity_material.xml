<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="24dp"
    tools:context=".ui.home.MaterialActivity">


    <androidx.cardview.widget.CardView
        android:id="@+id/card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/white"
        android:layout_alignParentTop="true"

        >

        <com.google.android.flexbox.FlexboxLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@color/white"
            android:orientation="horizontal">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_flexBasisPercent="15%"
                android:background="@color/white"
                >
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="10dp"
                    android:layout_centerHorizontal="true"
                    android:src="@drawable/back_24">

                </ImageView>

            </RelativeLayout>

            <TextView
                android:id="@+id/lable_screen_header"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:textAlignment="center"
                android:layout_marginVertical="4dp"
                android:text="DANH SÁCH VẬT TƯ"
                app:layout_flexBasisPercent="70%"
                android:textColor="@color/black"
                android:textSize="27sp"
                />


            <ImageView
                android:id="@+id/language_menu_inventory_scan"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:visibility="gone"
                android:layout_centerVertical="true"
                android:layout_alignParentRight="true"
                android:padding="10dp"
                android:src="@drawable/translation_2"/>


            <RelativeLayout
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                app:layout_alignSelf="center"
                app:layout_flexBasisPercent="15%"
                android:background="@color/white"
                >

                <ImageView
                    android:id="@+id/user_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/user_icon"
                    android:layout_centerHorizontal="true"
                    >

                </ImageView>


                <TextView
                    android:id="@+id/user_id_login"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/user_icon"
                    android:layout_centerHorizontal="true"
                    android:gravity="center"
                    android:text="028355"
                    android:textSize="13sp"
                    >

                </TextView>

            </RelativeLayout>


        </com.google.android.flexbox.FlexboxLayout>

    </androidx.cardview.widget.CardView>



    <LinearLayout
        android:id="@+id/lable_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_vertical"
        android:layout_below="@+id/card_view"
        android:layout_marginTop="10dp"
        >
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/txtwarehouseinformation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="Thông tin xuất kho"
                android:textStyle="bold"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="10dp"
                android:textSize="16sp"
                android:layout_centerVertical="true"/>

            <LinearLayout
                android:id="@+id/btn_show_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:gravity="center"
                >
                <TextView
                    android:id="@+id/txt_lable_show_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thu gọn"
                    android:textSize="14sp"
                    android:textColor="#01A789"
                    >
                </TextView>
                <ImageView
                    android:id="@+id/img_show_list"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:padding="5dp"
                    android:src="@drawable/uprow_line"
                    >

                </ImageView>
            </LinearLayout>



        </RelativeLayout>

    </LinearLayout>




    <TextView
        android:id="@+id/txt_lable_warehouse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lable_header"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:textStyle="bold"
        android:text="Chọn kho vật tư"
        >
    </TextView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/txt_lable_warehouse"
        android:layout_below="@+id/lable_header"
        android:layout_marginTop="16dp"
        android:textColor="@color/red"
        android:textSize="14sp"
        android:text="*"
        >

    </TextView>
    <AutoCompleteTextView
        android:id="@+id/cb_select_warehouse"
        android:layout_width="235dp"
        android:layout_height="wrap_content"
        android:minHeight="50dp"
        android:layout_below="@+id/txt_lable_warehouse"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="8dp"
        android:hint="Chọn thông tin"
        android:background="@drawable/package_box_background"
        >

    </AutoCompleteTextView>
    <ImageView
        android:id="@+id/btn_select_warehouse"
        android:layout_width="50dp"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="-8dp"
        android:layout_alignBottom="@+id/cb_select_warehouse"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:padding="3dp"
        android:layout_below="@+id/txt_lable_warehouse"
        android:layout_toEndOf="@+id/cb_select_warehouse"
        android:src="@drawable/customer_dropdown_icon"
        android:background="@drawable/layout_radius_topright_bottomright"
        >

    </ImageView>


    <TextView
        android:id="@+id/txt_lable_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lable_header"
        android:layout_toEndOf="@+id/btn_select_warehouse"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:text="Ngày yêu cầu hoàn thành"
        android:textStyle="bold"
        >
    </TextView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/txt_lable_date"
        android:layout_below="@+id/lable_header"
        android:textColor="@color/red"
        android:textSize="14sp"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="16dp"
        android:text="*"
        >

    </TextView>
    <AutoCompleteTextView
        android:id="@+id/cb_select_date"
        android:layout_width="235dp"
        android:layout_height="match_parent"
        android:layout_alignBottom="@+id/cb_select_warehouse"
        android:layout_below="@+id/txt_lable_warehouse"
        android:layout_toEndOf="@+id/btn_select_warehouse"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="15dp"
        android:hint="dd/MM/yyyy"
        android:gravity="center_vertical"
        android:textSize="18sp"
        android:background="@drawable/package_box_background"
        >

    </AutoCompleteTextView>
    <ImageView
        android:id="@+id/btn_show_datepicker"
        android:layout_width="50dp"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="-8dp"
        android:layout_alignBottom="@+id/cb_select_warehouse"
        android:padding="3dp"
        android:layout_below="@+id/txt_lable_warehouse"
        android:layout_toEndOf="@+id/cb_select_date"
        android:src="@drawable/customer_dropdown_icon"
        android:background="@drawable/layout_radius_topright_bottomright"
        >

    </ImageView>

    <TextView
        android:id="@+id/txtlabel_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/btn_show_datepicker"
        android:layout_marginRight="12dp"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="16dp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:text="Ghi chú" />

    <TextView
        android:id="@+id/txtlabel_note_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/btn_show_datepicker"
        android:layout_toEndOf="@+id/txtlabel_note"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:textColor="@color/red"
        android:textSize="16sp"
        android:text="*" />

    <EditText
        android:id="@+id/txt_note"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="16dp"
        android:padding="10dp"
        android:hint="Điền thông tin ghi chú"
        android:textStyle="italic"
        android:layout_below="@+id/txtlabel_note"
        android:background="@drawable/layout_bg_black"
        >

    </EditText>

    <TextView
        android:id="@+id/txt_lable_table_material"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="16dp"
        android:layout_below="@+id/txt_note"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:text="Danh sách vật tư"
        >

    </TextView>





    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txt_lable_table_material"
        android:layout_marginTop="10dp"
        >

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/rcv_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="#D1CFCF">

            <!-- Machine Code -->
            <TextView
                android:id="@+id/txt_no"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="NO"
                android:textStyle="bold"
                android:layout_marginLeft="1dp"
                android:layout_marginTop="1dp"
                android:background="#EFEFEF"
                app:layout_flexBasisPercent="10%"
                android:textColor="@color/black" />

            <!-- Machine Code -->
            <TextView
                android:id="@+id/materialCode"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="Mã vật tư"
                android:textStyle="bold"
                android:layout_marginLeft="1dp"
                android:layout_marginTop="1dp"
                android:background="#EFEFEF"
                app:layout_flexBasisPercent="20%"
                android:textColor="@color/black" />


            <!-- Maintenance Name -->
            <TextView
                android:id="@+id/materialName"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center"
                app:layout_flexBasisPercent="52.5%"
                android:textStyle="bold"
                android:layout_marginLeft="1dp"
                android:layout_marginTop="1dp"
                android:textColor="@color/black"
                android:background="#EFEFEF"
                android:text="Tên vật tư"/>

            <TextView
                android:id="@+id/material_qty"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="Số lượng"
                android:textStyle="bold"
                android:layout_marginLeft="1dp"
                android:layout_marginTop="1dp"
                android:textColor="@color/black"
                android:background="#EFEFEF"
                app:layout_flexBasisPercent="13.75%"
                />


            <TextView
                android:id="@+id/materialUnit"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="Đơn vị"
                android:textStyle="bold"
                android:layout_marginLeft="1dp"
                android:layout_marginTop="1dp"
                android:layout_marginRight="1dp"
                android:textColor="@color/black"
                android:background="#EFEFEF"
                app:layout_flexBasisPercent="13.75%"/>

        </com.google.android.flexbox.FlexboxLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcv_list_material"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:orientation="vertical"
            android:layout_below="@+id/rcv_header"
            android:background="@drawable/table_border"
            >

        </androidx.recyclerview.widget.RecyclerView>


    </RelativeLayout>


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        >

        <RelativeLayout
            android:id="@+id/btn_back_home"
            android:layout_width="285dp"
            android:layout_height="48dp"
            android:layout_alignParentBottom="true"
            android:layout_marginLeft="10dp"
            android:layout_marginBottom="55dp"
            android:gravity="center"
            android:background="@drawable/lay_out_conner_4_red_white"
            >


            <TextView
                android:id="@+id/btn_back_lable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:textAlignment="center"
                android:layout_marginLeft="5dp"
                android:text="Quay lại"
                android:textSize="14sp"
                android:textColor="@color/black"
                >

            </TextView>


        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/btn_export_material"
            android:layout_width="285dp"
            android:layout_height="48dp"
            android:layout_alignParentBottom="true"
            android:layout_marginLeft="12dp"
            android:layout_marginBottom="55dp"
            android:gravity="center"
            android:layout_toEndOf="@+id/btn_back_home"
            android:background="@drawable/lay_out_conner_4_green_white"
            >

            <ImageView
                android:id="@+id/endworkicon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:layout_marginLeft="7dp"
                android:src="@drawable/file_add"
                >
            </ImageView>


            <TextView
                android:id="@+id/btn_creat_material_export_lable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/endworkicon"
                android:layout_centerVertical="true"
                android:textAlignment="center"
                android:layout_marginLeft="5dp"
                android:text="Tạo yêu cầu xuất kho"
                android:textSize="14sp"
                android:textColor="@color/black"
                >

            </TextView>


        </RelativeLayout>


    </RelativeLayout>






</RelativeLayout>