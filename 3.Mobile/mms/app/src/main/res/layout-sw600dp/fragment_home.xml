<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.home.HomeFragment">

    <RelativeLayout
        android:id="@+id/lct1"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        >


            <View
                android:id="@+id/dividerView"
                android:layout_width="4dp"
                android:layout_height="28dp"
                android:background="#007AFF"
                android:layout_marginRight="8dp"
                android:layout_marginLeft="16dp"
                app:layout_flexBasisPercent="1%"
                android:layout_centerVertical="true"
                />

            <TextView
                android:id="@+id/txtlabel_Directivecode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginRight="12dp"
                android:textStyle="bold"
                android:layout_toEndOf="@+id/dividerView"
                android:textColor="@color/black"
                android:textSize="20sp"
                app:layout_flexBasisPercent="90%"
                android:text="Danh sách hạng mục công việc" />


        <RelativeLayout
            android:id="@+id/btn_add_new_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="7dp"
            android:background="@drawable/border_bg_d9"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@+id/btn_history_machine"
            >

            <ImageView
                android:id="@+id/icon_add"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginLeft="15dp"
                android:src="@drawable/setting_red"
                android:layout_centerVertical="true"
                >


            </ImageView>

            <TextView
                android:id="@+id/txt_add_new_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/icon_add"
                android:layout_centerVertical="true"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:text="Báo lỗi mới"
                android:textSize="14dp"
                android:textColor="#F44949"
                >

            </TextView>


        </RelativeLayout>


        <RelativeLayout
            android:id="@+id/btn_history_machine"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/border_bg_d9"
            android:layout_toEndOf="@+id/txtlabel_Directivecode"
            android:layout_marginRight="16dp"
            android:layout_centerVertical="true"
            >

            <ImageView
                android:id="@+id/icon_history_machine"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginLeft="15dp"
                android:src="@drawable/blank_calendar"
                android:layout_centerVertical="true"
                >


            </ImageView>

            <TextView
                android:id="@+id/txt_history_machine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/icon_history_machine"
                android:layout_centerVertical="true"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="10dp"
                android:text="Lịch sử máy"
                android:textSize="14dp"
                android:textColor="#01A789"
                >

            </TextView>


        </RelativeLayout>




    </RelativeLayout>


    <RelativeLayout
        android:id="@+id/lct0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lct1"
        android:gravity="center_horizontal"
        >

        <RelativeLayout
            android:id="@+id/lct2"
            android:layout_width="285dp"
            android:layout_height="36dp"

            android:layout_marginLeft="16dp"
            >

            <TextView
                android:id="@+id/btn_tab_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Công việc cần làm"
                android:textAlignment="center"
                android:layout_centerInParent="true"
                android:textSize="14sp"
                android:textColor="#6A1039"
                >

            </TextView>

            <TextView
                android:id="@+id/line_tab_1"
                android:layout_width="376dp"
                android:layout_height="2dp"
                android:text=""
                android:textAlignment="center"
                android:layout_alignParentBottom="true"
                android:textSize="14sp"
                android:background="#6A1039"
                >

            </TextView>


        </RelativeLayout>

        <RelativeLayout
            android:layout_width="285dp"
            android:layout_height="36dp"
            android:layout_toEndOf="@+id/lct2"
            >

            <TextView
                android:id="@+id/btn_tab_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đã hoàn thành"
                android:textAlignment="center"
                android:layout_centerInParent="true"
                android:textSize="14sp"
                android:textColor="#5C5C5C"
                >

            </TextView>

            <TextView
                android:id="@+id/line_tab_2"
                android:layout_width="376dp"
                android:layout_height="2dp"
                android:text=""
                android:textAlignment="center"
                android:layout_alignParentBottom="true"
                android:textSize="14sp"
                android:background="#F4F2F2"
                >

            </TextView>


        </RelativeLayout>



    </RelativeLayout>


    <RelativeLayout
        android:id="@+id/layout_tab1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/lct0"
        android:visibility="visible"
        >

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/lct3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3.4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_flexBasisPercent="100%"
                >

                <EditText
                    android:id="@+id/txt_find"
                    android:layout_width="160dp"
                    android:layout_height="35dp"
                    android:layout_marginLeft="16dp"
                    android:textSize="14sp"
                    android:hint="Tìm kiếm ..."
                    android:textAlignment="center"
                    android:background="@drawable/package_box_background"
                    >
                </EditText>

                <ImageView
                    android:id="@+id/ckeck1"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="6dp"
                    android:layout_marginLeft="5dp"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@+id/txt_find"
                    android:src="@drawable/check_inprogess"
                    >

                </ImageView>


                <TextView
                    android:id="@+id/txt_lable_ckeck1"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:layout_toEndOf="@+id/ckeck1"
                    android:layout_centerVertical="true"
                    android:textColor="@color/black"
                    android:text="Đang thực hiện (00)"
                    >

                </TextView>

                <ImageView
                    android:id="@+id/ckeck2"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="6dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="4dp"
                    android:layout_toEndOf="@+id/txt_lable_ckeck1"
                    android:src="@drawable/checkbox_pending"
                    >

                </ImageView>

                <TextView
                    android:id="@+id/txt_lable_ckeck2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/ckeck2"
                    android:layout_centerVertical="true"
                    android:textColor="@color/black"
                    android:text="Chưa thực hiện (00)"
                    >

                </TextView>


                <ImageView
                    android:id="@+id/ckeck3"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="6dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="4dp"
                    android:layout_toEndOf="@+id/txt_lable_ckeck2"
                    android:src="@drawable/checkbox_over"
                    >

                </ImageView>

                <TextView
                    android:id="@+id/txt_lable_ckeck3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/ckeck3"
                    android:layout_centerVertical="true"
                    android:textColor="@color/black"
                    android:text="Quá hạn (00)"
                    >

                </TextView>

            </LinearLayout>

        </com.google.android.flexbox.FlexboxLayout>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh_layout_param"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/lct3"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="60dp"
            >
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_list_task_month"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                >
            </androidx.recyclerview.widget.RecyclerView>


        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


        <RelativeLayout
            android:id="@+id/layout_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            >

            <RelativeLayout
                android:id="@+id/btn_get_list_material"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_alignParentBottom="true"
                android:layout_marginLeft="16dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/lay_out_conner_4_yellow_white"
                >

                <ImageView
                    android:id="@+id/materialicon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="7dp"
                    android:src="@drawable/material_icon"
                    >
                </ImageView>

                <TextView
                    android:id="@+id/btn_material_lable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/materialicon"
                    android:layout_centerVertical="true"
                    android:textAlignment="center"
                    android:layout_marginLeft="5dp"
                    android:text="Vật tư"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    >

                </TextView>

                <TextView
                    android:id="@+id/txt_material_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/btn_material_lable"
                    android:layout_centerVertical="true"
                    android:textAlignment="center"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:text="(0)"
                    android:textSize="14sp"
                    android:textColor="#F5B500">


                </TextView>


            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/btn_do_work"
                android:layout_width="205dp"
                android:layout_height="48dp"
                android:layout_alignParentBottom="true"
                android:layout_marginLeft="16dp"
                android:layout_marginBottom="20dp"
                android:layout_toEndOf="@+id/btn_get_list_material"
                android:background="@drawable/lay_out_conner_4_green_white"
                >

                <ImageView
                    android:id="@+id/doworkicon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="7dp"
                    android:src="@drawable/icon_custom_button"
                    >
                </ImageView>


                <TextView
                    android:id="@+id/btn_dowork_lable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/doworkicon"
                    android:layout_centerVertical="true"
                    android:textAlignment="center"
                    android:layout_marginLeft="5dp"
                    android:text="Thực hiện công việc"
                    android:textSize="14sp"
                    android:textColor="#01A789"
                    >

                </TextView>


            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/btn_end_work"
                android:layout_width="205dp"
                android:layout_height="48dp"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="16dp"
                android:layout_marginLeft="16dp"
                android:layout_marginBottom="21dp"
                android:layout_toEndOf="@+id/btn_do_work"
                android:background="@drawable/lay_out_conner_4_green_fill">

                <ImageView
                    android:id="@+id/endworkicon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="7dp"
                    android:src="@drawable/icon_select_button"></ImageView>


                <TextView
                    android:id="@+id/btn_endwork_lable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="5dp"
                    android:layout_toEndOf="@+id/endworkicon"
                    android:text="Hoàn thành công việc"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp">

                </TextView>


            </RelativeLayout>


        </RelativeLayout>

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/layout_tab2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="0dp"
        android:layout_below="@+id/lct0"
        android:visibility="gone">

        <EditText
            android:id="@+id/txt_find_tab2"
            android:layout_width="215dp"
            android:layout_height="35dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/package_box_background"
            android:hint="Tìm kiếm ...."
            android:textAlignment="center"
            android:textSize="14sp">


        </EditText>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginLeft="30dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/search_16"
            >
        </ImageView>

        <TextView
            android:id="@+id/txt_from_lable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/txt_find_tab2"
            android:layout_marginTop="16dp"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:text="Từ"
            >


        </TextView>

        <TextView
            android:id="@+id/txtlabel_date"
            android:layout_width="120dp"
            android:layout_height="35dp"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="10dp"
            android:layout_toEndOf="@+id/txt_from_lable"
            android:text="02/02/2025"
            android:background="@drawable/package_box_background"
            >
        </TextView>

        <ImageView
            android:id="@+id/btn_select_date"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="5dp"
            android:layout_toEndOf="@+id/txtlabel_date"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="-35dp"
            android:src="@drawable/customer_dropdown_icon"
            >

        </ImageView>

        <TextView
            android:id="@+id/txt_todate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/btn_select_date"
            android:layout_marginTop="16dp"
            android:layout_marginLeft="15dp"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:text="Đến"
            >


        </TextView>

        <TextView
            android:id="@+id/txtlabel_to_date"
            android:layout_width="120dp"
            android:layout_height="35dp"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="10dp"
            android:layout_toEndOf="@+id/txt_todate"
            android:text="28/02/2025"
            android:background="@drawable/package_box_background"
            >
        </TextView>

        <ImageView
            android:id="@+id/btn_select_to_date"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="5dp"
            android:layout_toEndOf="@+id/txt_todate"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="95dp"
            android:src="@drawable/customer_dropdown_icon"
            >

        </ImageView>



        <RelativeLayout
            android:id="@+id/lct4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
           android:gravity="center"
            android:layout_below="@+id/btn_select_to_date"
            >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3.4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_flexBasisPercent="100%"
                >



                <ImageView
                    android:id="@+id/ckeck4"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="6dp"
                    android:layout_marginLeft="5dp"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@+id/txt_find"
                    android:src="@drawable/check_type_3"
                    >

                </ImageView>


                <TextView
                    android:id="@+id/txt_lable_ckeck4"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:layout_toEndOf="@+id/ckeck1"
                    android:layout_centerVertical="true"
                    android:textColor="@color/black"
                    android:text="Đã thực hiện (00)"
                    >

                </TextView>

                <ImageView
                    android:id="@+id/ckeck5"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="6dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="4dp"
                    android:layout_toEndOf="@+id/txt_lable_ckeck1"
                    android:src="@drawable/checkbox_tick"
                    >

                </ImageView>

                <TextView
                    android:id="@+id/txt_lable_ckeck5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/ckeck2"
                    android:layout_centerVertical="true"
                    android:textColor="@color/black"
                    android:text="Đã phê duyệt OK (00)"
                    >

                </TextView>


                <ImageView
                    android:id="@+id/ckeck6"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="6dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="4dp"
                    android:layout_toEndOf="@+id/txt_lable_ckeck2"
                    android:src="@drawable/check_type_red"
                    >

                </ImageView>

                <TextView
                    android:id="@+id/txt_lable_ckeck6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/ckeck3"
                    android:layout_centerVertical="true"
                    android:textColor="@color/black"
                    android:text="Đã phê duyệt NG (00)"
                    >

                </TextView>

            </LinearLayout>

        </RelativeLayout>


        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh_layout_param_end_work"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_below="@+id/lct4"
            android:layout_marginBottom="16dp"
            android:layout_above="@+id/btn_approve"
            >

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_list_task_succees"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                >
            </androidx.recyclerview.widget.RecyclerView>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>




        <RelativeLayout
            android:id="@+id/btn_approve"
            android:layout_width="205dp"
            android:layout_height="48dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="16dp"
            android:layout_marginLeft="16dp"
            android:gravity="center"
            android:background="@drawable/lay_out_conner_4_green_fill">

            <ImageView
                android:id="@+id/approveicon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:layout_marginLeft="7dp"
                android:src="@drawable/icon_select_button"></ImageView>


            <TextView
                android:id="@+id/btn_approve_lable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="5dp"
                android:layout_toEndOf="@+id/approveicon"
                android:text="Phê duyệt"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp">

            </TextView>


        </RelativeLayout>


    </RelativeLayout>




</RelativeLayout>