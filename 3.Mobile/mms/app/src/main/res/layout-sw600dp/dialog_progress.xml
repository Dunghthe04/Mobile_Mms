<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_white_conner_8"
    android:orientation="vertical"
    android:layout_marginLeft="16dp"
    android:layout_marginRight="16dp"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="60dp"
        android:textColor="@color/black"
        android:text="Tạm dừng công việc"
        android:textStyle="bold"
        android:textSize="18sp"/>


    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_alignParentRight="true"
        android:layout_above="@+id/tvQuestion"
        android:src="@drawable/close_24"
        >

    </ImageView>

    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvTitle"
        android:layout_marginTop="8dp"
        android:textColor="@color/black"
        android:text="Bạn đã hoàn thành được bao nhiêu (%) khối lượng công việc ?" />

    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        android:layout_centerHorizontal="true"
        android:textColor="#01A789"
        android:textSize="16sp"
        android:layout_below="@+id/tvQuestion"
        android:layout_gravity="center_horizontal"/>


    <TextView
        android:id="@+id/min_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:layout_below="@+id/tvProgress"
        >


    </TextView>


    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvProgress"
        android:layout_toEndOf="@+id/min_value"
        android:layout_marginRight="25dp"
        android:progressDrawable="@drawable/custom_seekbar"
        android:thumb="@drawable/custom_thumb"
        android:max="100"
        android:progress="0"/>



    <TextView
        android:id="@+id/max_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="100"
        android:textColor="#01A789"
        android:textSize="14sp"
        android:layout_below="@+id/tvProgress"
        android:layout_alignParentRight="true"
        >


    </TextView>


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="right"
        android:layout_below="@+id/seekBar"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="152dp"
            android:layout_height="40dp"
            android:text="Hủy"
            android:gravity="center"
            android:textColor="@color/red"
            android:background="@drawable/layout_bg_red"/>

        <TextView
            android:id="@+id/btnConfirm"
            android:layout_width="152dp"
            android:layout_height="40dp"
            android:layout_toEndOf="@+id/btnCancel"
            android:text="Xác nhận"
            android:layout_marginLeft="8dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/lay_out_conner_4_green_fill"/>
    </RelativeLayout>
</RelativeLayout>
