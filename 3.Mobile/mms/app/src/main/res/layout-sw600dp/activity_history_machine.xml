<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="24dp"
    tools:context=".ui.home.HistoryMachineActivity">


    <RelativeLayout
        android:id="@+id/lct1"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        >

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/back_24"
            android:padding="10dp"
            android:layout_marginRight="8dp"
            android:layout_marginLeft="16dp"
            android:layout_centerVertical="true"
            />
        <TextView
            android:id="@+id/txtlabel_screen_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginRight="12dp"
            android:textStyle="bold"
            android:layout_toEndOf="@+id/btn_back"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:text="Lịch sử sửa chữa bảo trì máy" />


    </RelativeLayout>

    <TextView
        android:id="@+id/txt_lable_machine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lct1"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginLeft="16dp"
        android:text="Mã máy - Tên máy"
        >
    </TextView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/txt_lable_machine"
        android:layout_below="@+id/lct1"
        android:textColor="@color/red"
        android:textSize="14sp"
        android:text="*"
        >

    </TextView>
    <AutoCompleteTextView
        android:id="@+id/cb_select_machine"
        android:layout_width="235dp"
        android:layout_height="wrap_content"
        android:minHeight="40dp"
        android:layout_below="@+id/txt_lable_machine"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="8dp"
        android:hint="Chọn thông tin"
        android:background="@drawable/package_box_background"
        >

    </AutoCompleteTextView>
    <ImageView
        android:id="@+id/btn_select_machine"
        android:layout_width="50dp"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="-8dp"
        android:layout_alignBottom="@+id/cb_select_machine"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:padding="3dp"
        android:layout_below="@+id/txt_lable_machine"
        android:layout_toEndOf="@+id/cb_select_machine"
        android:src="@drawable/customer_dropdown_icon"
        android:background="@drawable/layout_radius_topright_bottomright"
        >

    </ImageView>


    <TextView
        android:id="@+id/txt_from_lable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/btn_select_machine"
        android:layout_below="@+id/lct1"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginLeft="16dp"
        android:textColor="@color/black"
        android:text="Từ"
        >


    </TextView>
    <TextView
        android:id="@+id/txtlabel_date"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:layout_toEndOf="@+id/btn_select_machine"
        android:layout_marginLeft="16dp"
        android:textColor="@color/black"
        android:layout_below="@+id/txt_from_lable"
        android:text="02/02/2025"
        android:background="@drawable/package_box_background"
        >
    </TextView>
    <ImageView
        android:id="@+id/btn_select_date"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:padding="5dp"
        android:layout_toEndOf="@+id/txtlabel_date"
        android:layout_marginTop="12dp"
        android:layout_marginLeft="-35dp"
        android:layout_below="@+id/txt_from_lable"
        android:src="@drawable/customer_dropdown_icon"
        >

    </ImageView>

    <TextView
        android:id="@+id/txt_todate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/btn_select_date"
        android:layout_marginLeft="15dp"
        android:layout_below="@+id/lct1"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:text="Đến"
        >


    </TextView>
    <TextView
        android:id="@+id/txtlabel_to_date"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:textColor="@color/black"
        android:layout_toEndOf="@+id/btn_select_date"
        android:layout_marginLeft="15dp"
        android:layout_below="@+id/txt_todate"
        android:text="28/02/2025"
        android:background="@drawable/package_box_background"
        >
    </TextView>
    <ImageView
        android:id="@+id/btn_select_to_date"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:padding="5dp"
        android:layout_toEndOf="@+id/txtlabel_to_date"
        android:layout_below="@+id/txt_todate"
        android:layout_marginTop="12dp"
        android:layout_marginLeft="-35dp"
        android:src="@drawable/customer_dropdown_icon"
        >

    </ImageView>


    <TextView
        android:id="@+id/txt_lable_type_machine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/cb_select_machine"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:text="Loại máy"
        >
    </TextView>
    <TextView
        android:id="@+id/txt_type_machine"
        android:layout_width="280dp"
        android:layout_height="40dp"
        android:layout_below="@+id/txt_lable_type_machine"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="8dp"
        android:text="-"
        android:background="@drawable/package_box_background"
        >
    </TextView>

    <TextView
        android:id="@+id/txt_task_type_lable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/btn_select_machine"
        android:layout_below="@+id/cb_select_machine"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:textColor="@color/black"
        android:text="Loại công việc"
        >


    </TextView>
    <AutoCompleteTextView
        android:id="@+id/cb_select_task_type"
        android:layout_width="210dp"
        android:layout_height="wrap_content"
        android:minHeight="40dp"
        android:layout_below="@+id/txt_task_type_lable"
        android:layout_toEndOf="@+id/btn_select_machine"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="8dp"
        android:hint="Chọn thông tin"
        android:background="@drawable/package_box_background"
        >

    </AutoCompleteTextView>
    <ImageView
        android:id="@+id/btn_select_task_type"
        android:layout_width="50dp"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="-8dp"
        android:layout_alignBottom="@+id/cb_select_task_type"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:padding="3dp"
        android:layout_below="@+id/txt_task_type_lable"
        android:layout_toEndOf="@+id/cb_select_task_type"
        android:src="@drawable/customer_dropdown_icon"
        android:background="@drawable/layout_radius_topright_bottomright"
        >

    </ImageView>

    <TextView
        android:id="@+id/txt_lable_table"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txt_type_machine"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:text="Danh sách công việc"
        >
    </TextView>


    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/rcv_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@+id/txt_lable_table"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:background="@drawable/layout_radius_topleft_topright">

        <!-- TextView -->
        <TextView
            android:id="@+id/txt_lable_date_header"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="1dp"
            android:layout_marginLeft="1dp"
            android:layout_marginBottom="1dp"
            app:layout_flexBasisPercent="15%"
            android:text="Ngày"
            android:textColor="@color/black"
            android:gravity="center"
            android:textStyle="bold"
            android:background="@drawable/layout_radius_topleft"
            />

        <!-- Task Type -->
        <TextView
            android:id="@+id/taskType"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Loại"
            android:textStyle="bold"
            android:layout_marginLeft="1dp"
            android:layout_marginTop="1dp"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="10%"
            android:textColor="@color/black" />

        <!-- Machine Code -->
        <TextView
            android:id="@+id/machineCode"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Mã máy"
            android:textStyle="bold"
            android:layout_marginLeft="1dp"
            android:layout_marginTop="1dp"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="15%"
            android:textColor="@color/black" />

        <!-- Maintenance Name -->
        <TextView
            android:id="@+id/maintenanceName"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:textStyle="bold"
            app:layout_flexBasisPercent="32.5%"
            android:layout_marginLeft="1dp"
            android:layout_marginTop="1dp"
            android:textColor="@color/black"
            android:background="#EFEFEF"
            android:text="Tên hạng mục"/>

        <TextView
            android:id="@+id/material"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Vật tư"
            android:textStyle="bold"
            android:layout_marginLeft="1dp"
            android:layout_marginTop="1dp"
            android:textColor="@color/black"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="13.75%"
            />


        <TextView
            android:id="@+id/progess"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Tiến độ"
            android:textStyle="bold"
            android:layout_marginLeft="1dp"
            android:layout_marginTop="1dp"
            android:layout_marginRight="1dp"
            android:textColor="@color/black"
            android:background="@drawable/layout_radius_topright"
            app:layout_flexBasisPercent="13.75%"/>

    </com.google.android.flexbox.FlexboxLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_list_history_machine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/rcv_header"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="55dp"
        >

    </androidx.recyclerview.widget.RecyclerView>








</RelativeLayout>