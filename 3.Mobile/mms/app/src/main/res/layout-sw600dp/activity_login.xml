<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/actlogin"
    android:background="#F2F2F2F2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".ui.login.LoginActivity">


    <ImageView
        android:id="@+id/companyLogo"
        android:layout_width="match_parent"
        android:layout_height="91dp"
        android:layout_alignParentTop="true"
        android:layout_marginTop="80dp"
        android:paddingHorizontal="20dp"
        android:src="@drawable/meiko_logo_2" />

    <TextView
        android:id="@+id/usernameLabel"
        android:layout_marginBottom="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User name"
        android:textSize="16sp"
        android:layout_marginTop="25dp"
        android:textColor="@color/grey"
        android:layout_below="@id/companyLogo"/>

    <FrameLayout
        android:id="@+id/usernameInputContainer"
        android:layout_below="@id/usernameLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/custom_text_input_background"
        android:padding="14dp">


        <EditText
            android:background="@drawable/white_border_background"
            android:id="@+id/usernameInput"
            android:inputType="text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="18sp" />

    </FrameLayout>


    <!-- Password Input -->
    <TextView
        android:layout_marginBottom="10dp"
        android:id="@+id/passwordLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Password"
        android:textSize="16sp"
        android:textColor="@color/grey"
        android:layout_below="@id/usernameInputContainer"
        android:layout_marginTop="16dp"/>

    <FrameLayout
        android:layout_below="@id/passwordLabel"
        android:id="@+id/passwordInputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/custom_text_input_background"
        android:padding="14dp">


        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="299dp"
            android:layout_height="wrap_content"
            android:background="@drawable/white_border_background"
            android:inputType="textPassword"
            android:textColor="@color/black"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/btn_show_password"
            android:layout_width="25dp"
            android:layout_height="24dp"
            android:layout_gravity="end"
            android:src="@drawable/eye_slash"
            >

        </ImageView>

    </FrameLayout>


    <!-- Login Button -->
    <Button
        android:id="@+id/loginButton"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:textSize="18sp"
        android:backgroundTint="#03358E"
        android:layout_below="@+id/passwordInputContainer"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="LOGIN"
        android:textColor="#FFFFFF" />




    <ImageView
        android:id="@+id/connect_server_status"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/networknone"
        >

    </ImageView>
    <!-- Company Tag -->
    <TextView
        android:id="@+id/companyTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Product of Meiko Automation"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:textColor="#BEBEBE	"
        android:textSize="14sp"
        />
    <!-- Language selection -->
    <RelativeLayout
        android:id="@+id/languageLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="0dp">

        <ImageView
            android:id="@+id/earthIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/language_icon" />

        <TextView
            android:id="@+id/languageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/earthIcon"
            android:text="Language"
            android:layout_marginLeft="10px"
            android:textColor="@color/gray"
            android:textSize="16sp" />

    </RelativeLayout>

    <TextView
        android:id="@+id/VersionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/connect_server_status"
        android:layout_marginStart="0dp"
        android:text=""
        android:textColor="@color/gray"
        android:textSize="16sp" />





</RelativeLayout>