<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="24dp"
    tools:context=".ui.home.NewErrorActivity">

    <RelativeLayout
        android:id="@+id/lct1"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        >

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/back_24"
            android:padding="10dp"
            android:layout_marginRight="8dp"
            android:layout_marginLeft="16dp"
            android:layout_centerVertical="true"
            />
        <TextView
            android:id="@+id/txtlabel_Directivecode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginRight="12dp"
            android:textStyle="bold"
            android:layout_toEndOf="@+id/btn_back"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:text="Báo lỗi mới" />


    </RelativeLayout>


    <TextView
        android:id="@+id/txt_lable_machine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lct1"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginLeft="16dp"
        android:textStyle="bold"
        android:text="Mã máy - Tên máy"
        >
    </TextView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/txt_lable_machine"
        android:layout_below="@+id/lct1"
        android:textColor="@color/red"
        android:textSize="14sp"
        android:text="*"
        >

    </TextView>
    <AutoCompleteTextView
        android:id="@+id/cb_select_machine"
        android:layout_width="165dp"
        android:layout_height="wrap_content"
        android:minHeight="50dp"
        android:layout_below="@+id/txt_lable_machine"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="8dp"
        android:hint="Chọn thông tin"
        android:background="@drawable/package_box_background"
        >

    </AutoCompleteTextView>
    <ImageView
        android:id="@+id/btn_select_machine"
        android:layout_width="25dp"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="-8dp"
        android:layout_alignBottom="@+id/cb_select_machine"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:padding="3dp"
        android:layout_below="@+id/txt_lable_machine"
        android:layout_toEndOf="@+id/cb_select_machine"
        android:src="@drawable/customer_dropdown_icon"
        android:background="@drawable/layout_radius_topright_bottomright"
        >

    </ImageView>


    <TextView
        android:id="@+id/txt_lable_error_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lct1"
        android:layout_toEndOf="@+id/btn_select_machine"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginLeft="16dp"
        android:text="Loại lỗi"
        android:textStyle="bold"
        >
    </TextView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/txt_lable_error_type"
        android:layout_below="@+id/lct1"
        android:textColor="@color/red"
        android:textSize="14sp"
        android:layout_marginLeft="5dp"
        android:text="*"
        >

    </TextView>
    <AutoCompleteTextView
        android:id="@+id/cb_select_type_error"
        android:layout_width="165dp"
        android:layout_height="match_parent"
        android:layout_alignBottom="@+id/cb_select_machine"
        android:layout_below="@+id/txt_lable_machine"
        android:layout_toEndOf="@+id/btn_select_machine"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="15dp"
        android:hint="Chọn thông tin"
        android:gravity="center_vertical"
        android:textSize="18sp"
        android:background="@drawable/package_box_background"
        >

    </AutoCompleteTextView>
    <ImageView
        android:id="@+id/btn_type_error"
        android:layout_width="25dp"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="-8dp"
        android:layout_alignBottom="@+id/cb_select_machine"
        android:padding="3dp"
        android:layout_below="@+id/txt_lable_machine"
        android:layout_toEndOf="@+id/cb_select_type_error"
        android:src="@drawable/customer_dropdown_icon"
        android:background="@drawable/layout_radius_topright_bottomright"
        >

    </ImageView>


    <TextView
        android:id="@+id/txt_lable_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/cb_select_machine"
        android:layout_marginTop="12dp"
        android:layout_marginLeft="16dp"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:text="Nội dung lỗi"
        android:textStyle="bold"
        >

    </TextView>
    <TextView
        android:layout_width="35dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_below="@+id/cb_select_machine"
        android:layout_toEndOf="@+id/txt_lable_content"
        android:textColor="@color/red"
        android:text="*"
        >

    </TextView>
    <EditText
        android:id="@+id/txt_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txt_lable_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginTop="8dp"
        android:hint=""
        android:background="@drawable/package_box_background"
        >

    </EditText>

    <TextView
        android:id="@+id/lable_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txt_content"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="16dp"
        android:textColor="@color/black"
        android:text="Ảnh hiện trạng"
        android:textStyle="bold"
        >
    </TextView>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_list_img_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lable_image"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginTop="8dp"
        >

    </androidx.recyclerview.widget.RecyclerView>


    <TextView
        android:id="@+id/txt_lable_upload"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="16dp"
        android:layout_below="@+id/rcv_list_img_error"
        android:text="Tải lên file"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        >
    </TextView>

    <com.mkac.meikomms.ui.custom.UploadButton
        android:id="@+id/pickImageBtn"
        android:layout_width="272dp"
        android:layout_height="40dp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="8dp"
        android:layout_below="@+id/txt_lable_upload"
        >

    </com.mkac.meikomms.ui.custom.UploadButton>


    <ImageView
        android:id="@+id/cameraBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/camera_40"
        android:layout_below="@+id/txt_lable_upload"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="15dp"
        android:layout_toEndOf="@+id/pickImageBtn"
        >
    </ImageView>

    <RelativeLayout
        android:id="@+id/btn_add_error"
        android:layout_width="285dp"
        android:layout_height="48dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/cameraBtn"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:background="@drawable/lay_out_conner_4_green_fill"
        >

        <ImageView
            android:id="@+id/startworkicon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="7dp"
            android:src="@drawable/icon_select_button"
            >
        </ImageView>


        <TextView
            android:id="@+id/btn_save_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/startworkicon"
            android:layout_centerVertical="true"
            android:textAlignment="center"
            android:layout_marginLeft="5dp"
            android:text="Xác nhận"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            >

        </TextView>


    </RelativeLayout>


    <TextView
        android:id="@+id/txt_lable_list_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginRight="16dp"
        android:layout_below="@+id/btn_add_error"
        android:text="Danh sách báo lỗi"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="visible"
        android:textColor="@color/black"
        >
    </TextView>


    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/rcv_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@+id/txt_lable_list_error"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:visibility="visible"
        android:background="@drawable/layout_radius_topleft_topright">

        <!-- Task Type -->
        <TextView
            android:id="@+id/error_code"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Mã lỗi"
            android:textStyle="bold"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="15%"
            android:textColor="@color/black" />

        <!-- Machine Code -->
        <TextView
            android:id="@+id/machineCode"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Mã máy"
            android:textStyle="bold"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="15%"
            android:textColor="@color/black" />

        <!-- Issue Code -->
        <TextView
            android:id="@+id/issueCode"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Loại lỗi"
            android:textStyle="bold"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="15%"
            android:textColor="@color/black" />

        <!-- Maintenance Name -->
        <TextView
            android:id="@+id/Error_content"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:textStyle="bold"
            app:layout_flexBasisPercent="45%"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:textColor="@color/black"
            android:background="#EFEFEF"
            android:text="Nội dung lỗi"/>


        <TextView
            android:id="@+id/progess"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text=""
            android:textStyle="bold"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:layout_marginRight="1dp"
            android:textColor="@color/black"
            android:background="@drawable/layout_radius_topright"
            app:layout_flexBasisPercent="10%"/>

    </com.google.android.flexbox.FlexboxLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_list_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/rcv_header"
        android:visibility="visible"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="55dp"
        >

    </androidx.recyclerview.widget.RecyclerView>



</RelativeLayout>