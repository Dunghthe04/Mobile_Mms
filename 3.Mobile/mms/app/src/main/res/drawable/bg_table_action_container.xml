<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle shadow layer for enterprise depth -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0000000A" />
        </shape>
    </item>
    
    <!-- Main container with professional gradient -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#FAFBFC"
                android:endColor="#F3F5F7" />
            <stroke
                android:width="1dp"
                android:color="#E8EAED" />
        </shape>
    </item>
</layer-list>
