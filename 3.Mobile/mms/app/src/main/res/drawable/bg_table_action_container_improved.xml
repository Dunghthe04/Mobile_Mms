<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer for depth -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000015" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    
    <!-- Main container background with gradient -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#FFFFFF"
                android:endColor="#F5F7FA" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#E5E8ED" />
        </shape>
    </item>
</layer-list>
