<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipe_refresh_work_order"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Summary -->
        <TextView
            android:id="@+id/tv_work_order_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F7FBFA"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp"
            android:text="Machine Code: -- | Quantity: 0"
            android:textColor="#00A680"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Machine Code: MC-0021 | Quantity: 5" />

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_work_order_data"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp"
            android:scrollbars="vertical" />

    </LinearLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>