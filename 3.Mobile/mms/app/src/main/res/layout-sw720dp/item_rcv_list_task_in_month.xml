<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:background="@android:color/white">


    <!-- Date -->
    <TextView
        android:id="@+id/txt_date_task"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="left"
        android:text="Ngày 02/02/2025"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:textColor="@color/black"
        />


    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/rcv_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@+id/txt_date_task"
        android:layout_marginTop="5dp"
        android:background="@drawable/layout_radius_topleft_topright">

        <!-- Checkbox -->
        <CheckBox
            android:id="@+id/checkBox"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="1dp"
            android:layout_marginLeft="1dp"
            android:layout_marginBottom="1dp"
            app:layout_flexBasisPercent="5%"
            android:background="@drawable/layout_radius_topleft"
            />

        <!-- Task Type -->
        <TextView
            android:id="@+id/taskType"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Loại"
            android:textStyle="bold"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="10%"
            android:textColor="@color/black" />

        <!-- Machine Code -->
        <TextView
            android:id="@+id/machineCode"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Mã máy"
            android:textStyle="bold"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="12.5%"
            android:textColor="@color/black" />

        <!-- Issue Code -->
        <TextView
            android:id="@+id/issueCode"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Mã báo lỗi"
            android:textStyle="bold"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="12.5%"
            android:textColor="@color/black" />

        <!-- Maintenance Name -->
        <TextView
            android:id="@+id/maintenanceName"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:textStyle="bold"
            app:layout_flexBasisPercent="32.5%"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:textColor="@color/black"
            android:background="#EFEFEF"
            android:text="Tên hạng mục"/>

        <TextView
            android:id="@+id/material"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Vật tư"
            android:textStyle="bold"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:textColor="@color/black"
            android:background="#EFEFEF"
            app:layout_flexBasisPercent="13.75%"
            />


        <TextView
            android:id="@+id/progess"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Tiến độ"
            android:textStyle="bold"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="1dp"
            android:layout_marginRight="1dp"
            android:textColor="@color/black"
            android:background="@drawable/layout_radius_topright"
            app:layout_flexBasisPercent="13.75%"/>

    </com.google.android.flexbox.FlexboxLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_list_task"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/rcv_header"
        android:background="@drawable/table_border"
        >
    </androidx.recyclerview.widget.RecyclerView>



</RelativeLayout>
