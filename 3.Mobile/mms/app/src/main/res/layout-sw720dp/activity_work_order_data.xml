<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/work_order_data_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="28dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:contentDescription="@null"
            android:padding="6dp"
            android:src="@drawable/back_24" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Enter Work Order Data"
            android:textColor="@color/black"
            android:textSize="26sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#EEEEEE" />

    <LinearLayout
        android:id="@+id/layout_tabs"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:paddingHorizontal="28dp">

        <RelativeLayout
            android:id="@+id/tab_work_order_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
                android:id="@+id/btn_tab_work_order"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="Work Order"
                android:textColor="#00A680"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/line_tab_work_order"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_alignParentBottom="true"
                android:background="#00A680" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/tab_maintenance_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
                android:id="@+id/btn_tab_maintenance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="Maintenance"
                android:textColor="#5C5C5C"
                android:textSize="20sp" />

            <View
                android:id="@+id/line_tab_maintenance"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_alignParentBottom="true"
                android:background="#F4F2F2" />
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_machine_scan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="8dp"
        android:background="#F7FBFA"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="16dp">

        <ImageView
            android:id="@+id/btn_scan_machine"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:contentDescription="@null"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="#00A680" />

        <TextView
            android:id="@+id/tv_machine_scan_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Machine not scanned"
            android:textColor="#2B2B2B"
            android:textSize="18sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_filters_work_order"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginVertical="8dp"
        android:orientation="horizontal"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/btn_filter_wo_date"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.2"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_filter_segment_unselected"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#5C5C5C" />

            <TextView
                android:id="@+id/tv_filter_wo_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text=""
                android:textColor="#2B2B2B"
                android:textSize="16sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_filter_segment_unselected"
            android:paddingHorizontal="8dp">

            <Spinner
                android:id="@+id/spinner_filter_wo_status"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:dropDownWidth="match_parent"
                android:gravity="center_vertical"
                android:spinnerMode="dropdown" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_filters_maintenance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginVertical="8dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/btn_filter_maint_date"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.2"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_filter_segment_unselected"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#5C5C5C" />

            <TextView
                android:id="@+id/tv_filter_maint_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Dự kiến: Tất cả"
                android:textColor="#2B2B2B"
                android:textSize="16sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_filter_segment_unselected"
            android:paddingHorizontal="8dp">

            <Spinner
                android:id="@+id/spinner_filter_maint_status"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:dropDownWidth="match_parent"
                android:gravity="center_vertical"
                android:spinnerMode="dropdown" />
        </FrameLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>