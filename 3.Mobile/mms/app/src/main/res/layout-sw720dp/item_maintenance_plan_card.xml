<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="#D4D9E2"
    app:strokeWidth="1.2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_plan_machine_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textColor="#111827"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_plan_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#F3F4F6"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="Pending"
                android:textColor="#4B5563"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Chưa làm" />
        </LinearLayout>

        <!-- Category -->
        <TextView
            android:id="@+id/tv_plan_category_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Category Name"
            android:textColor="#1F2937"
            android:textSize="18sp"
            tools:text="Hạng mục" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#E5E7EB" />

        <!-- Info Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Left -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_plan_assignee_user"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Person in charge"
                    android:textColor="#6B7280"
                    android:textSize="16sp"
                    tools:text="Phụ trách" />

                <TextView
                    android:id="@+id/tv_plan_executor_user"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Execute task"
                    android:textColor="#6B7280"
                    android:textSize="16sp"
                    tools:text="Thực hiện" />
            </LinearLayout>

            <!-- Right -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_plan_task_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plan"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    tools:text="Dự kiến" />

                <TextView
                    android:id="@+id/tv_plan_done_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Done"
                    android:textColor="#047857"
                    android:textSize="16sp"
                    tools:text="Xong" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_plan_edit"
            style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:text="Proceed with inspection"
            android:textColor="#01A789"
            android:textSize="15sp"
            android:textStyle="bold"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconSize="18dp"
            app:iconTint="#01A789"
            tools:text="Tiến hành kiểm tra" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>