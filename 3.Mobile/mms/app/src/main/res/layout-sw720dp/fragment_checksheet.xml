<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap"
                app:justifyContent="space_evenly">

                <LinearLayout
                    android:id="@+id/ln_ma"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_margin="8dp"
                    android:clickable="true">

                    <CheckBox
                        android:id="@+id/cb_ma_bao_su_co"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#FF99FF"
                        android:checked="true"
                        android:padding="0dp"
                        android:clickable="false" />

                    <TextView
                        android:id="@+id/tv_count_ma"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="MA đã báo sự cố: 0"
                        android:textColor="@color/black"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ln_fe_tiep_nhan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_margin="8dp"
                    android:clickable="true">

                    <CheckBox
                        android:id="@+id/cb_fe_tiep_nhan"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#FEFE9A"
                        android:checked="true"
                        android:padding="0dp"
                        android:clickable="false" />

                    <TextView
                        android:id="@+id/tv_count_fe_tiep_nhan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="FE đã tiếp nhận: 0"
                        android:textColor="@color/black"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ln_fe_phan_cong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_margin="8dp"
                    android:clickable="true">

                    <CheckBox
                        android:id="@+id/cb_fe_phan_cong"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#98FE69"
                        android:checked="true"
                        android:padding="0dp"
                        android:clickable="false" />

                    <TextView
                        android:id="@+id/tv_count_fe_phan_cong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="FE đã phân công: 0"
                        android:textColor="@color/black"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.flexbox.FlexboxLayout>

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:flexWrap="wrap"
                app:justifyContent="space_evenly">

                <LinearLayout
                    android:id="@+id/ln_fe_hoan_tat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_margin="8dp"
                    android:clickable="true">

                    <CheckBox
                        android:id="@+id/cb_fe_hoan_tat"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#66CCFD"
                        android:checked="true"
                        android:padding="0dp"
                        android:clickable="false" />

                    <TextView
                        android:id="@+id/tv_count_fe_hoan_tat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="FE đã hoàn tất việc xử lý bất thường: 0"
                        android:textColor="@color/black"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ln_huy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_margin="8dp"
                    android:clickable="true">

                    <CheckBox
                        android:id="@+id/cb_huy"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:buttonTint="#ABABAB"
                        android:checked="true"
                        android:padding="0dp"
                        android:clickable="false" />

                    <TextView
                        android:id="@+id/tv_count_huy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Hủy: 0"
                        android:textColor="@color/black"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.flexbox.FlexboxLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginTop="20dp"
            android:background="@color/white"
            android:orientation="horizontal"
            android:padding="0.5dp"
            android:weightSum="100">

            <TextView
                android:id="@+id/tv_progress_ma"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="20"
                android:background="#FF99FF"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_progress_fe_tiep_nhan"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="20"
                android:background="#FEFE9A"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_progress_fe_phan_cong"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="20"
                android:background="#98FE69"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_progress_fe_hoan_tat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="20"
                android:background="#66CCFD"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_progress_huy"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="20"
                android:background="#ABABAB"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="10sp" />
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="01:00"
                    android:textColor="@color/red"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <!-- Nút THÊM mới -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    app:cardCornerRadius="8dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/gray"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/btn_list_wo"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="16dp"
                        android:text="Work Order"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textSize="12sp" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    app:cardCornerRadius="8dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/gray"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/btn_filter_day"
                            android:layout_width="60dp"
                            android:layout_height="match_parent"
                            android:text="Ngày"
                            android:gravity="center"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/gray" />

                        <TextView
                            android:id="@+id/btn_filter_week"
                            android:layout_width="60dp"
                            android:layout_height="match_parent"
                            android:text="Tuần"
                            android:gravity="center"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/gray" />

                        <TextView
                            android:id="@+id/btn_filter_month"
                            android:layout_width="60dp"
                            android:layout_height="match_parent"
                            android:text="Tháng"
                            android:gravity="center"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    app:cardCornerRadius="8dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/gray"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tv_start_date"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Từ ngày"
                        android:textSize="12sp" />
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="15dp"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/black" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="8dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/gray"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tv_end_date"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Đến ngày"
                        android:textSize="12sp" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/table_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="0.5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/black">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.5"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="STT"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="Mã hệ\nthống"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="Nhà máy"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="Công\nđoạn"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="Tên thiết\nbị"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="Vị trí"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="Hiện\ntrạng"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="Trạng thái\nsản xuất"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="Ngày\nbáo cáo"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="0.5dp"
                android:paddingVertical="12dp"
                android:background="@color/filter_header"
                android:gravity="center"
                android:text="Trạng\nthái"
                android:textStyle="bold"
                android:textColor="@color/black" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_checksheet"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/white"
            android:padding="0dp"
            android:clipToPadding="false" />
    </LinearLayout>

</LinearLayout>
