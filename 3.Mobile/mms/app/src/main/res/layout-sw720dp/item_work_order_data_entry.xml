<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeColor="#D4D9E2"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_item_no"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_add"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_item_wo_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WO-XXXX"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_item_machine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Machine"
                    android:textColor="#6B7280"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_enter_work_order"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="@drawable/bg_btn_add"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="Nhập WO"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_item_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Content"
            android:textColor="#374151"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_item_request_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="21/05/2026"
            android:textColor="#9CA3AF"
            android:textSize="12sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>