<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/work_order_hub_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Header: đồng bộ layout-sw720dp/activity_list_work_order -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Work Order"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layout_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/update_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                android:src="@drawable/refresh_cw_green" />

            <TextView
                android:id="@+id/tv_username_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Guest"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/img_user_profile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@null"
                android:src="@drawable/user_icon" />
        </LinearLayout>
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tv_hub_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chọn chức năng"
            android:textColor="#6B7280"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_hub_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp"
            android:text="Tạo work order mới hoặc nhập dữ liệu work order và bảo dưỡng"
            android:textColor="@color/black"
            android:textSize="15sp" />

        <!-- Tablet: 2 thẻ ngang -->
        <com.google.android.flexbox.FlexboxLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:alignItems="stretch"
            app:flexWrap="nowrap"
            app:justifyContent="space_evenly">

            <!-- 1. Thêm mới Work Order -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_create_work_order"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp"
                app:layout_flexBasisPercent="48%"
                app:layout_flexGrow="1"
                app:strokeColor="#00A680"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/btn_create_work_order"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:minHeight="200dp"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_btn_add">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@android:drawable/ic_input_add"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_create_work_order_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Thêm mới Work Order"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_create_work_order_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Tạo work order"
                        android:textColor="#6B7280"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Nhập dữ liệu Work Order & Bảo dưỡng -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_enter_work_order_data"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp"
                app:layout_flexBasisPercent="48%"
                app:layout_flexGrow="1"
                app:strokeColor="#01A789"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/btn_enter_work_order_data"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:minHeight="200dp"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="#01A789">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_pencil"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_enter_work_order_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Nhập dữ liệu Work Order, Bảo dưỡng"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_enter_work_order_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Quản lý phiếu công việc và thực hiện bảo dưỡng"
                        android:textColor="#6B7280"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </com.google.android.flexbox.FlexboxLayout>

    </LinearLayout>

</LinearLayout>
